-- =========================================
-- TAMBAHKAN UNIQUE CONSTRAINT pada nim (jika belum ada)
-- =========================================
DO $$
BEGIN
    IF NOT EXISTS (
        SELECT 1 
        FROM pg_constraint 
        WHERE conname = 'users_nim_unique'
    ) THEN
        ALTER TABLE users ADD CONSTRAINT users_nim_unique UNIQUE (nim);
    END IF;
END $$;

-- =========================================
-- BACKFILL: Buat data magang untuk mahasiswa yang sudah ada
-- =========================================
INSERT INTO magang (nim, status_magang)
SELECT u.nim, 'belum_daftar'
FROM users u
WHERE u.role = 'mahasiswa'
AND u.nim IS NOT NULL
AND NOT EXISTS (
    SELECT 1 FROM magang m WHERE m.nim = u.nim
);

-- =========================================
-- CEK HASIL PERBAIKAN
-- =========================================
-- Lihat data users
SELECT 
    nim,
    nama_lengkap,
    email,
    role::text as role,
    created_at
FROM users
ORDER BY created_at DESC
LIMIT 10;

-- Lihat data magang
SELECT 
    m.id_magang,
    m.nim,
    m.status_magang::text as status_magang,
    m.created_at as magang_created,
    u.nama_lengkap,
    u.email
FROM magang m
LEFT JOIN users u ON m.nim = u.nim
ORDER BY m.created_at DESC
LIMIT 10;

-- Cek mahasiswa yang belum punya data magang
SELECT 
    u.nim,
    u.nama_lengkap,
    u.email
FROM users u
WHERE u.role = 'mahasiswa'
AND u.nim IS NOT NULL
AND NOT EXISTS (
    SELECT 1 FROM magang m WHERE m.nim = u.nim
);

