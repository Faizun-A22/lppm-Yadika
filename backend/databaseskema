-- =========================================
-- TRIGGER FUNCTIONS (YANG DIPERBAIKI)
-- =========================================

-- Hapus trigger dan function yang lama
DROP TRIGGER IF EXISTS trigger_create_magang ON users;
DROP FUNCTION IF EXISTS create_magang_for_new_user();

-- Buat function baru dengan benar (gunakan nim)
CREATE OR REPLACE FUNCTION create_magang_for_new_user()
RETURNS TRIGGER AS $$
BEGIN
    -- Hanya untuk mahasiswa dan nim tidak null
    IF NEW.role = 'mahasiswa' AND NEW.nim IS NOT NULL THEN
        -- Insert ke tabel magang menggunakan nim
        INSERT INTO magang (nim, status_magang) 
        VALUES (NEW.nim, 'belum_daftar');
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

-- Buat trigger baru
CREATE TRIGGER trigger_create_magang
AFTER INSERT ON users
FOR EACH ROW
WHEN (NEW.role = 'mahasiswa')
EXECUTE FUNCTION create_magang_for_new_user();

-- Function untuk create riwayat magang
CREATE OR REPLACE FUNCTION create_riwayat_magang()
RETURNS TRIGGER AS $$
BEGIN
    INSERT INTO riwayat_magang (
        id_magang, 
        tipe_riwayat, 
        deskripsi,
        status_lama,
        status_baru
    ) VALUES (
        NEW.id_magang,
        'status_update',
        'Status magang berubah dari ' || COALESCE(OLD.status_magang::text, 'null') || ' menjadi ' || NEW.status_magang::text,
        OLD.status_magang::text,
        NEW.status_magang::text
    );
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trigger_riwayat_magang
AFTER UPDATE ON magang
FOR EACH ROW
WHEN (OLD.status_magang IS DISTINCT FROM NEW.status_magang)
EXECUTE FUNCTION create_riwayat_magang();

