-- =========================================
-- EXTENSION
-- =========================================
CREATE EXTENSION IF NOT EXISTS "pgcrypto";

-- =========================================
-- ENUM
-- =========================================
CREATE TYPE user_role AS ENUM ('admin','dosen','mahasiswa');
CREATE TYPE status_akun AS ENUM ('aktif','nonaktif');

CREATE TYPE status_submission AS ENUM (
    'draft','submit','review','diterima','ditolak','revisi'
);

CREATE TYPE status_publish AS ENUM ('draft','publish');
CREATE TYPE rekomendasi_review AS ENUM ('diterima','revisi','ditolak');

-- =========================================
-- USERS
-- =========================================
CREATE TABLE users (
    id_user UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    nama_lengkap VARCHAR(150) NOT NULL,
    email VARCHAR(150) UNIQUE NOT NULL,
    password TEXT NOT NULL,
    role user_role NOT NULL,
    nidn VARCHAR(30),
    nim VARCHAR(30),
    prodi VARCHAR(100),
    no_hp VARCHAR(20),
    foto_profil TEXT,
    status status_akun DEFAULT 'aktif',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- =========================================
-- JENIS JURNAL
-- =========================================
CREATE TABLE jenis_jurnal (
    id_jenis_jurnal UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    nama_jurnal VARCHAR(100) NOT NULL,
    deskripsi TEXT,
    issn VARCHAR(50),
    tahun_terbit INT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- =========================================
-- JURNAL
-- =========================================
CREATE TABLE jurnal (
    id_jurnal UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    id_jenis_jurnal UUID REFERENCES jenis_jurnal(id_jenis_jurnal) ON DELETE CASCADE,
    judul VARCHAR(255) NOT NULL,
    abstrak TEXT,
    file_pdf TEXT NOT NULL,
    penulis_utama UUID REFERENCES users(id_user) ON DELETE SET NULL,
    status status_submission DEFAULT 'draft',
    tanggal_submit TIMESTAMP,
    tanggal_publish TIMESTAMP,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- =========================================
-- JURNAL PENULIS
-- =========================================
CREATE TABLE jurnal_penulis (
    id_penulis UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    id_jurnal UUID REFERENCES jurnal(id_jurnal) ON DELETE CASCADE,
    id_user UUID REFERENCES users(id_user) ON DELETE CASCADE,
    peran VARCHAR(50)
);

-- =========================================
-- PENELITIAN
-- =========================================
CREATE TABLE penelitian (
    id_penelitian UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    judul VARCHAR(255) NOT NULL,
    skema_penelitian VARCHAR(150),
    sumber_dana VARCHAR(150),
    tahun INT,
    ketua_peneliti UUID REFERENCES users(id_user) ON DELETE SET NULL,
    file_proposal TEXT,
    file_laporan TEXT,
    status status_submission DEFAULT 'draft',
    tanggal_pengajuan TIMESTAMP,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- =========================================
-- ANGGOTA PENELITIAN
-- =========================================
CREATE TABLE anggota_penelitian (
    id_anggota UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    id_penelitian UUID REFERENCES penelitian(id_penelitian) ON DELETE CASCADE,
    id_user UUID REFERENCES users(id_user) ON DELETE CASCADE,
    peran VARCHAR(100)
);

-- =========================================
-- PENGABDIAN
-- =========================================
CREATE TABLE pengabdian (
    id_pengabdian UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    judul VARCHAR(255) NOT NULL,
    lokasi VARCHAR(255),
    ketua_pengabdian UUID REFERENCES users(id_user) ON DELETE SET NULL,
    tahun INT,
    file_proposal TEXT,
    file_laporan TEXT,
    status status_submission DEFAULT 'draft',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- =========================================
-- ANGGOTA PENGABDIAN
-- =========================================
CREATE TABLE anggota_pengabdian (
    id_anggota UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    id_pengabdian UUID REFERENCES pengabdian(id_pengabdian) ON DELETE CASCADE,
    id_user UUID REFERENCES users(id_user) ON DELETE CASCADE,
    peran VARCHAR(100)
);

-- =========================================
-- BERITA
-- =========================================
CREATE TABLE berita (
    id_berita UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    judul VARCHAR(255) NOT NULL,
    isi_berita TEXT NOT NULL,
    gambar_thumbnail TEXT,
    id_admin UUID REFERENCES users(id_user) ON DELETE SET NULL,
    status status_publish DEFAULT 'draft',
    tanggal_publish TIMESTAMP,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- =========================================
-- REVIEW JURNAL
-- =========================================
CREATE TABLE review_jurnal (
    id_review UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    id_jurnal UUID REFERENCES jurnal(id_jurnal) ON DELETE CASCADE,
    reviewer UUID REFERENCES users(id_user) ON DELETE SET NULL,
    catatan TEXT,
    rekomendasi rekomendasi_review,
    tanggal_review TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- =========================================
-- LOG AKTIVITAS
-- =========================================
CREATE TABLE log_aktivitas (
    id_log UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    id_user UUID REFERENCES users(id_user) ON DELETE SET NULL,
    aktivitas TEXT,
    waktu TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- =========================================
-- TRIGGER AUTO UPDATE updated_at
-- =========================================
CREATE OR REPLACE FUNCTION update_timestamp()
RETURNS TRIGGER AS $$
BEGIN
   NEW.updated_at = CURRENT_TIMESTAMP;
   RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER update_users_timestamp
BEFORE UPDATE ON users
FOR EACH ROW EXECUTE FUNCTION update_timestamp();

CREATE TRIGGER update_jurnal_timestamp
BEFORE UPDATE ON jurnal
FOR EACH ROW EXECUTE FUNCTION update_timestamp();

CREATE TRIGGER update_penelitian_timestamp
BEFORE UPDATE ON penelitian
FOR EACH ROW EXECUTE FUNCTION update_timestamp();

CREATE TRIGGER update_pengabdian_timestamp
BEFORE UPDATE ON pengabdian
FOR EACH ROW EXECUTE FUNCTION update_timestamp();

CREATE TRIGGER update_berita_timestamp
BEFORE UPDATE ON berita
FOR EACH ROW EXECUTE FUNCTION update_timestamp();

-- =========================================
-- AUTO SET tanggal_submit JURNAL
-- =========================================
CREATE OR REPLACE FUNCTION set_tanggal_submit()
RETURNS TRIGGER AS $$
BEGIN
   IF NEW.status = 'submit' THEN
      NEW.tanggal_submit = CURRENT_TIMESTAMP;
   END IF;
   RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER jurnal_submit_trigger
BEFORE UPDATE ON jurnal
FOR EACH ROW
WHEN (OLD.status IS DISTINCT FROM NEW.status)
EXECUTE FUNCTION set_tanggal_submit();

-- =========================================
-- AUTO SET tanggal_publish BERITA
-- =========================================
CREATE OR REPLACE FUNCTION set_publish_date()
RETURNS TRIGGER AS $$
BEGIN
   IF NEW.status = 'publish' THEN
      NEW.tanggal_publish = CURRENT_TIMESTAMP;
   END IF;
   RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER berita_publish_trigger
BEFORE UPDATE ON berita
FOR EACH ROW
WHEN (OLD.status IS DISTINCT FROM NEW.status)
EXECUTE FUNCTION set_publish_date();

-- =========================================
-- VIEW DASHBOARD STATISTIK
-- =========================================
CREATE VIEW dashboard_statistik AS
SELECT
    (SELECT COUNT(*) FROM jurnal) AS total_jurnal,
    (SELECT COUNT(*) FROM penelitian) AS total_penelitian,
    (SELECT COUNT(*) FROM pengabdian) AS total_pengabdian,
    (SELECT COUNT(*) FROM berita WHERE status = 'publish') AS total_berita_publish;

-- =========================================
-- INDEXING (PERFORMA)
-- =========================================
CREATE INDEX idx_jurnal_status ON jurnal(status);
CREATE INDEX idx_penelitian_status ON penelitian(status);
CREATE INDEX idx_berita_status ON berita(status);

-- =========================================
-- ENUM untuk Magang
-- =========================================
CREATE TYPE status_magang AS ENUM (
    'belum_daftar',
    'pendaftaran_diproses',
    'pendaftaran_diterima',
    'pendaftaran_ditolak',
    'data_perusahaan_diproses',
    'data_perusahaan_diterima',
    'data_perusahaan_ditolak',
    'sedang_magang',
    'selesai_magang',
    'luaran_diproses',
    'luaran_diterima',
    'luaran_ditolak'
);

CREATE TYPE status_dokumen AS ENUM (
    'pending',
    'verified',
    'rejected'
);

ALTER ROLE postgres SET search_path TO public;

CREATE TABLE public.magang (
    id_magang UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    nim VARCHAR(30) NOT NULL,
    status_magang status_magang DEFAULT 'belum_daftar',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT fk_magang_user
        FOREIGN KEY (nim)
        REFERENCES public.users(nim)
        ON DELETE CASCADE
);

